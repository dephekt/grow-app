# grow-app configuration. Copy to `.env` for local runs, or set these in the
# deployment compose. Every `*_FILE` variant reads the value from a file (Docker
# secret mount) instead of the inline env.

# --- Site / MQTT ---------------------------------------------------------------
GROW_SITE=daniel-home
MQTT_URL=mqtt://localhost:1883
MQTT_USERNAME=grow-app-site-daniel-home
# MQTT_PASSWORD=
# MQTT_PASSWORD_FILE=/run/secrets/MQTT_GROW_APP_SITE_PASSWORD

# --- Auth: local accounts ------------------------------------------------------
# SQLite auth DB (users, sessions, audit). Needs a writable, persistent path.
# Defaults to ./data/auth.db in code; the container image sets this to
# /data/auth.db (Dockerfile ENV), with /data declared as a persistent volume.
# Uncomment only to relocate locally.
# GROW_AUTH_DB=./data/auth.db
# Auth-audit retention, enforced by the daily maintenance timer. Rows older than
# GROW_AUTH_AUDIT_RETENTION_DAYS are pruned, and only the newest
# GROW_AUTH_AUDIT_MAX_ROWS survive the sweep (a cap so an unauthenticated
# login.failed flood can't grow the table unbounded). Set either to 0 to disable
# that limit. Defaults shown.
# GROW_AUTH_AUDIT_RETENTION_DAYS=90
# GROW_AUTH_AUDIT_MAX_ROWS=50000
# Login throttle. POST /auth/login always runs a full scrypt (even for unknown
# users), so it is rate-limited per client IP and the number of concurrent
# derivations is capped, to keep an unauthenticated flood from monopolising the
# CPU/threadpool. GROW_AUTH_LOGIN_RATE_MAX attempts per client IP per
# GROW_AUTH_LOGIN_RATE_WINDOW_SECONDS then return 429; GROW_AUTH_LOGIN_MAX_INFLIGHT
# bounds simultaneous scrypt runs. Set MAX/INFLIGHT to 0 to disable that limit.
# Per-IP limiting needs real client IPs behind the proxy (see ADDRESS_HEADER
# below). Defaults shown.
# GROW_AUTH_LOGIN_RATE_MAX=10
# GROW_AUTH_LOGIN_RATE_WINDOW_SECONDS=60
# GROW_AUTH_LOGIN_MAX_INFLIGHT=8
# Bootstrap admin. Creates the admin on first boot and never overwrites an
# existing password. It is NOT fully inert afterward: whenever no enabled
# local-password admin remains, it re-enables and re-promotes this account as a
# recovery path — so unset GROW_AUTH_ADMIN_* once a durable admin exists, or a
# lingering value can resurrect a deliberately disabled admin. Provide a
# password OR a pre-computed scrypt hash.
GROW_AUTH_ADMIN_USERNAME=admin
# GROW_AUTH_ADMIN_PASSWORD=change-me
# GROW_AUTH_ADMIN_PASSWORD_FILE=/run/secrets/GROW_AUTH_ADMIN_PASSWORD
# GROW_AUTH_ADMIN_PASSWORD_HASH=scrypt$32768$8$1$...
# GROW_AUTH_ADMIN_PASSWORD_HASH_FILE=/run/secrets/GROW_AUTH_ADMIN_PASSWORD_HASH

# --- Auth: OIDC (optional; absent => local-auth-only) --------------------------
# grow-app is a confidential per-site OIDC client. SSO is enabled (the login page
# shows "Sign in with SSO") only when the issuer, client id, client secret, AND at
# least one allowed origin below are all set. Access is granted by group claim:
# membership in /grow-site-<GROW_SITE> or the global /grow-admin group; the admin
# group also grants app admin. On Keycloak, add a "Group Membership" mapper to the
# per-site client with claim name `groups`, Full group path ON, add to ID token.
# GROW_OIDC_ISSUER=https://auth.dephekt.net/realms/home
# GROW_OIDC_CLIENT_ID=grow-site-daniel-home
# GROW_OIDC_CLIENT_SECRET=
# GROW_OIDC_CLIENT_SECRET_FILE=/run/secrets/GROW_OIDC_CLIENT_SECRET
# Requested scopes (default: openid profile email). `openid` is mandatory.
# GROW_OIDC_SCOPES=openid profile email
# Per-request timeout (ms) for IdP calls (discovery/token/JWKS); a down IdP then
# fails a new login fast instead of stalling it. Default 5000.
# GROW_OIDC_HTTP_TIMEOUT_MS=5000
# Allow a plain-HTTP issuer (skip the HTTPS-only check). Default false — set true
# only for local testing or a trusted LAN-only IdP; a public issuer must be HTTPS.
# GROW_OIDC_ALLOW_INSECURE_ISSUER=false
# Comma-separated allowed OIDC redirect origins (public URL + LAN origin). Each
# origin's <origin>/auth/oidc/callback must be a Valid Redirect URI in Keycloak.
# GROW_AUTH_ORIGINS=https://daniel.grow.dephekt.net,http://192.168.8.3:3080

# --- Behind a TLS-terminating proxy (Pangolin) ---------------------------------
# Let adapter-node trust the forwarded scheme/host so session cookies get Secure
# on the public HTTPS origin.
# PROTOCOL_HEADER=x-forwarded-proto
# HOST_HEADER=x-forwarded-host
# Make getClientAddress() return the real client IP (from X-Forwarded-For) rather
# than the proxy's, so per-IP login rate limiting keys on the actual client. Only
# trustworthy when a proxy you control (Pangolin/Traefik terminates TLS here)
# always sets the header. XFF_DEPTH is the number of trusted proxies in front of
# the app (1 for a single reverse proxy). Without these, every proxied client
# shares the proxy's IP, so the per-IP cap acts as one shared global limit (one
# user's failed attempts count against everyone) and the in-flight cap becomes the
# real per-request defense. A request that arrives without the header (e.g. a
# direct plain-HTTP LAN request) falls back to a shared bucket rather than failing.
# ADDRESS_HEADER=x-forwarded-for
# XFF_DEPTH=1

# --- History (optional) --------------------------------------------------------
# INFLUX_URL=http://grow-influxdb:8086
# INFLUX_TOKEN_FILE=/run/secrets/INFLUXDB_ADMIN_TOKEN
# INFLUX_ORG=grow
# INFLUX_BUCKET=daniel-home

# --- Firmware OTA (optional) ---------------------------------------------------
# FIRMWARE_UPDATE_TOKEN_FILE=/run/secrets/FIRMWARE_UPDATE_TOKEN
