{
  "name": "grow-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.3",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": "11.5.3"
  },
  "scripts": {
    "dev": "vite dev --host 0.0.0.0",
    "build": "vite build",
    "build:recorder": "esbuild src/lib/server/history/recorder.ts --bundle --platform=node --format=esm --target=node24 --packages=external '--alias:$lib=./src/lib' --outfile=build-recorder/recorder.js",
    "start": "node build",
    "preview": "vite preview --host 127.0.0.1",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "design:screenshots": "playwright test e2e/design-screenshots.spec.ts"
  },
  "dependencies": {
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@influxdata/influxdb-client": "^1.35.0",
    "@sveltejs/adapter-node": "^5.2.12",
    "@sveltejs/kit": "^2.22.5",
    "mqtt": "^5.14.1",
    "svelte": "^5.34.3",
    "uplot": "^1.6.32",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.1",
    "@sveltejs/vite-plugin-svelte": "^5.1.0",
    "@types/node": "^24.0.4",
    "esbuild": "^0.28.1",
    "svelte-check": "^4.2.2",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
